# SearchAPI.io Configuration
# Required: Get your API key from https://serpapi.com/
SEARCHAPI_API_KEY=your_searchapi_key_here

# Application Configuration
APP_NAME=Hotel Search API
VERSION=1.0.0
DEBUG=false

# Server Configuration
HOST=0.0.0.0
PORT=8000

# SearchAPI.io Advanced Configuration (optional)
# SEARCHAPI_BASE_URL=https://serpapi.com
# SEARCHAPI_TIMEOUT=30
# SEARCHAPI_RETRIES=3

# Logging Configuration (optional)
# LOG_LEVEL=INFO

# Production Configuration (for deployment)
# WORKERS=4
